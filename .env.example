# Copier ce fichier vers .env et adapter les valeurs.

PORT=3029

# Base locale actuelle
DB_FILE=data/app.sqlite

# Database Configuration - PostgreSQL
# Laisser vide si tu veux utiliser uniquement SQLite.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=true
DATABASE_URL=

# Server Configuration
NODE_ENV=production
PORT=3029

# API Configuration
API_BASE_URL=https://api.1xbet.com
API_TIMEOUT=10000

# Cache Configuration
CACHE_TTL=3600
CACHE_SIZE=100

# Security
JWT_SECRET=change-me-in-production
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Telegram (envois coupon / match)
# TELEGRAM_BOT_TOKEN=

# Android / Push mobile (a preparer pour la release)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# ANDROID_PACKAGE_NAME=com.solitairehack.solitfifpro225

# Chat IA (optionnel) — voir documentation Anthropic / proxy
# ANTHROPIC_BASE_URL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=

# Fournisseur compatible OpenAI (POST .../v1/chat/completions, cle Bearer).
# Ne jamais committer la cle reelle. Alias optionnels: THE_OLD_API_BASE_URL, THE_OLD_API_KEY, THE_OLD_MODEL, THE_OLD_FIRST=1
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=gpt-4o
# OPENAI_COMPAT_FIRST=1
# URL liste modeles (GET, info seulement pour GET /api/chat): OPENAI_COMPAT_MODELS_URL=
